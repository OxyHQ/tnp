{
  "name": "@tnp/client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tnp": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts run",
    "dev": "bun --watch src/cli.ts run",
    "build": "bun build src/cli.ts --compile --outfile dist/tnp",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/tnp-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/tnp-linux-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/tnp-darwin-x64",
    "build:darwin-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/tnp-darwin-arm64",
    "build:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/tnp-windows-x64.exe"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97",
    "dns2": "^2.1.0",
    "tweetnacl": "^1.0.3"
  }
}
